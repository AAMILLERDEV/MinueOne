{
  "name": "Event",
  "type": "object",
  "properties": {
    "organizer_profile_id": {
      "type": "string",
      "description": "Profile ID of the event organizer"
    },
    "name": {
      "type": "string",
      "description": "Event name"
    },
    "description": {
      "type": "string",
      "description": "Event description"
    },
    "event_date": {
      "type": "string",
      "format": "date",
      "description": "Event date"
    },
    "location": {
      "type": "string",
      "description": "Event location"
    },
    "website_url": {
      "type": "string",
      "description": "Event website"
    },
    "cover_image_url": {
      "type": "string",
      "description": "Event cover image URL"
    },
    "attendee_csv_url": {
      "type": "string",
      "description": "URL to uploaded attendee CSV file"
    },
    "matched_attendee_count": {
      "type": "number",
      "default": 0,
      "description": "Number of matched attendees on platform"
    },
    "total_attendee_count": {
      "type": "number",
      "default": 0,
      "description": "Total attendees in uploaded list"
    },
    "is_verified": {
      "type": "boolean",
      "default": false,
      "description": "Event verified by platform"
    },
    "is_active": {
      "type": "boolean",
      "default": true,
      "description": "Event is active and accepting attendee links"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Event tags/categories"
    }
  },
  "required": [
    "organizer_profile_id",
    "name",
    "event_date"
  ]
}